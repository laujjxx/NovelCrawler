# ==================== LLM API 配置（可选，用于 AI 拆书分析） ====================
# 支持任何 OpenAI 兼容接口：OpenAI / DeepSeek / 通义千问 / Ollama / 小米 MiMo 等

LLM_API_KEY=your-api-key-here
LLM_API_BASE=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ==================== 代理设置（可选） ====================
# 如需使用系统代理，取消注释并设置
# PROXY_SERVER=http://127.0.0.1:7897
